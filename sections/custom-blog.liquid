{% schema %}
{
  "name": "UFC Blog Carousel",
  "blocks": [
    {
      "type": "@theme"
    },
    {
      "type": "@app"
    },
    {
      "type": "text"
    },
    {
      "type": "icon"
    },
    {
      "type": "image"
    },
    {
      "type": "button"
    },
    {
      "type": "video"
    },
    {
      "type": "group"
    },
    {
      "type": "spacer"
    },
    {
      "type": "_divider"
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "blog_title",
      "label": "Blog Title"
    },
    {
      "type": "blog",
      "id": "selected_blog",
      "label": "Choose Blog"
    }
  ],
  "presets": [{ "name": "UFC Blog Carousel" }]
}
{% endschema %}

{% assign selected_blog = section.settings.selected_blog %}
{% if selected_blog %}
  {% assign articles = blogs[selected_blog].articles %}
{% else %}
  {% assign articles = blog.articles %}
{% endif %}

<div class="ufc-carousel-container">
  <div class="ufc-ambient"></div>

  <div class="ufc-stage">
    <div class="ufc-blog-title">
      <h2>{{ section.settings.blog_title }}</h2>
    </div>
    <div class="ufc-carousel-wrap">
      <div class="ufc-viewport" id="ufc-viewport">
        <div class="ufc-track" id="ufc-track">
          {% for article in articles %}
            <div class="ufc-card" data-index="{{ forloop.index0 }}">
              <div class="ufc-card-img">
                <img src="{{ article.image | img_url: '800x800' }}" alt="{{ article.title }}">
                <a href="{{ article.url }}" class="ufc-hero-name-show">{{ article.metafields.custom.hero_name }}</a>
                <div class="ufc-hero-name">{{ article.title }}</div>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>

      <div class="ufc-dots" id="ufc-dots">
        {% for article in articles %}
          <div class="dot" data-index="{{ forloop.index0 }}"></div>
        {% endfor %}
      </div>
      <div id="ufc-selected-hero" class="ufc-selected-hero"></div>
    </div>

    <div class="ufc-vignette"></div>
  </div>
</div>

<style>
  :root {
    --accent: #fec909;
    --bg: #070708;
    --gap: 48px;
    --card-width-desktop: 39vmin;
    --card-width-mobile: 56vmin;
    /* --card-height:; */
  }

  /* Background */
  .ufc-carousel-container {
    position: relative;
    width: 100%;
    background: radial-gradient(circle at center, rgba(254, 201, 9, 0.16), transparent 70%),
      linear-gradient(180deg, var(--bg), #050506);
    overflow: hidden;
  }

  .ufc-ambient {
    position: fixed;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(600px 400px at 50% 50%, rgba(254, 201, 9, 0.1), transparent);
    opacity: 0.4;
  }

  /* Stage */
  .ufc-stage {
    position: relative;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ufc-carousel-wrap {
    width: 100%;
    max-width: 1600px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
  }

  .ufc-viewport {
    width: 100%;
    overflow: visible;
    display: flex;
    align-items: center;
    justify-content: center;
    height: calc(var(--card-size) + 150px);
    touch-action: pan-y;
  }

  .ufc-track {
    display: flex;
    gap: var(--gap);
    align-items: center;
    padding: 40px 20px;
    will-change: transform;
  }

  /* Card */
  @media screen and (min-width: 750px) {
    :root {
      --card-width: var(--card-width-desktop);
    }
    .ufc-selected-hero {
      font-size: 2.2rem;
      margin-top: 1.5rem;
      padding: 0 2rem;
    }
    .ufc-hero-name-show {
      position: absolute;
      right: 15px;
      bottom: 14px;
      padding: 6px 18px 6px 17px;
      font-family: inherit;
      font-weight: 700;
      font-size: 1rem;
      line-height: 1.25;
      color: black;
      background: var(--accent);
      box-shadow: 0 0 18px var(--accent);
    }
  }
  @media screen and (max-width: 749px) {
    :root {
      --card-width: var(--card-width-mobile);
    }
    .ufc-selected-hero {
      font-size: 1.5rem;
      margin-top: 1rem;
      padding: 0 2rem;
    }
    .ufc-hero-name-show {
      position: absolute;
      right: 13px;
      bottom: 8px;
      padding: 3px 10px 3px 8px;
      font-family: inherit;
      font-weight: 700;
      font-size: 0.7rem;
      line-height: 1.25;
      color: black;
      background: var(--accent);
      box-shadow: 0 0 18px var(--accent);
    }
  }
  .ufc-card {
    width: var(--card-width);
    /* height: var(--card-height); */
    height: auto;
    border-radius: 20px;
    background: #111;
    overflow: hidden;
    position: relative;
    cursor: grab;
    transition: transform 0.15s;
    filter: grayscale(100%) brightness(0.6);
    box-shadow: 0 10px 30px #000a;
    user-select: none;
    z-index: 2;
  }

  .ufc-link-inner {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    opacity: 0;
  }
  .ufc-card.center {
    filter: grayscale(0%) brightness(1);
    box-shadow: 0 0 40px var(--accent);
    z-index: 5;
  }

  .ufc-card-img img {
    width: 100%;
    aspect-ratio: 1 / 1.2;
    object-fit: cover;
    pointer-events: none;
  }

  .ufc-info {
    position: absolute;
    bottom: -16px;
    width: 100%;
    text-align: center;
    color: white;
  }

  .ufc-hero-name {
    font-size: 20px;
    font-weight: 700;
    color: var(--accent);
    display: none;
  }

  /* Disable clicks while dragging */
  .ufc-link {
    pointer-events: auto;
  }

  /* Dots */
  .ufc-dots {
    display: flex;
    gap: 10px;
    justify-content: center;
    margin-top: 11vmin;
  }
  .ufc-card.center .ufc-hero-name-show::after {
    content: '';
    position: absolute;
    inset: 0;
    border: 2px solid var(--accent);
    border-radius: inherit;
    transform: scale(1);
    opacity: 1;
    animation: ufc-border-zoom-out 1.6s infinite ease-out;
    z-index: 2;
  }

  @keyframes ufc-border-zoom-out {
    0% {
      transform: scale(1);
      opacity: 0.9;
      box-shadow: 0 0 18px var(--accent);
    }
    100% {
      transform: scale(1.3);
      opacity: 0;
      box-shadow: 0 0 2px transparent;
    }
  }

  .ufc-dots .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: #ffffff33;
    cursor: pointer;
  }

  .ufc-dots .active {
    background: var(--accent);
  }

  /* Vignette */
  .ufc-vignette {
    position: fixed;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(ellipse at center, transparent 50%, rgba(0, 0, 0, 0.8) 100%);
  }

  /* Prevent selection */
  *,
  *::before,
  *::after {
    user-select: none;
  }

  .ufc-selected-hero {
    text-align: center;
    color: var(--accent);
    font-weight: bold;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.35s, transform 0.35s;
    min-height: 40px;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
    text-decoration: underline;
  }
  .ufc-selected-hero.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const track = document.getElementById('ufc-track');
  const viewport = document.getElementById('ufc-viewport');
  const cards = [...track.children];
  const dots = [...document.querySelectorAll('#ufc-dots .dot')];

  let drag = { active: false, lastX: 0, velocity: 0 };

  /* Helpers */
  function getX() {
    const m = getComputedStyle(track).transform;
    if (m === 'none') return 0;
    return parseFloat(m.split(',')[4]);
  }

  function centerCard(index) {
    const vp = viewport.getBoundingClientRect();
    const card = cards[index].getBoundingClientRect();
    const center = vp.left + vp.width / 2;
    const move = center - (card.left + card.width / 2);

    track.style.transition = 'transform .35s cubic-bezier(.25,.9,.25,1)';
    track.style.transform = `translateX(${getX() + move}px)`;
    updateDots(index);

    setTimeout(scaleCards, 20);
  }

  /* Scale + highlight */
  function scaleCards() {
    const vp = viewport.getBoundingClientRect();
    const center = vp.left + vp.width / 2;
    let closestIdx = 0,
      closestDist = Infinity;
    cards.forEach((card, i) => {
      const r = card.getBoundingClientRect();
      const d = Math.abs(r.left + r.width / 2 - center);
      if (d < closestDist) {
        closestIdx = i;
        closestDist = d;
      }
    });

    cards.forEach((card, i) => {
      const r = card.getBoundingClientRect();
      const d = Math.abs(r.left + r.width / 2 - center);
      const t = Math.max(0, 1 - d / vp.width);
      const s = 1 + t * 0.45;
      card.style.transform = `scale(${s})`;
      card.style.zIndex = String(10 + Math.round(t * 20)); // higher z-index near center
      card.classList.toggle('center', i === closestIdx);
    });

    // Set hero name with animation
    const heroDisplay = document.getElementById('ufc-selected-hero');
    const heroName = (cards[closestIdx].querySelector('.ufc-hero-name')?.textContent || '').trim();
    if (heroDisplay) {
      if (heroDisplay.textContent !== heroName && heroName) {
        heroDisplay.classList.remove('visible'); // fade out
        setTimeout(() => {
          heroDisplay.textContent = heroName;
          heroDisplay.classList.add('visible'); // fade in
        }, 220);
      } else if (!heroDisplay.classList.contains('visible') && heroName) {
        heroDisplay.textContent = heroName;
        heroDisplay.classList.add('visible');
      }
    }
  }

  /* Dots */
  function updateDots(i) {
    dots.forEach((d) => d.classList.remove('active'));
    dots[i].classList.add('active');
  }

  dots.forEach((dot) => {
    dot.addEventListener('click', () => {
      centerCard(parseInt(dot.dataset.index));
    });
  });

  /* Dragging */
  viewport.addEventListener('pointerdown', (e) => {
    drag.active = true;
    drag.lastX = e.clientX;
    drag.velocity = 0;
    track.style.transition = 'none';

    // disable link clicks while dragging
    document.querySelectorAll('.ufc-link').forEach((a) => (a.style.pointerEvents = 'none'));
  });

  viewport.addEventListener('pointermove', (e) => {
    if (!drag.active) return;

    let dx = e.clientX - drag.lastX;
    drag.lastX = e.clientX;
    drag.velocity = dx;

    track.style.transform = `translateX(${getX() + dx}px)`;
    scaleCards();
  });

  function release() {
    if (!drag.active) return;
    drag.active = false;

    // re-enable clicks
    document.querySelectorAll('.ufc-link').forEach((a) => (a.style.pointerEvents = 'auto'));

    let v = drag.velocity;

    function inertia() {
      v *= 0.92;
      if (Math.abs(v) < 0.4) {
        let best = 0,
          dist = Infinity;

        const vp = viewport.getBoundingClientRect();
        const center = vp.left + vp.width / 2;

        cards.forEach((c, i) => {
          let r = c.getBoundingClientRect();
          let d = Math.abs(r.left + r.width / 2 - center);
          if (d < dist) {
            best = i;
            dist = d;
          }
        });

        centerCard(best);
        return;
      }

      track.style.transform = `translateX(${getX() + v}px)`;
      scaleCards();
      requestAnimationFrame(inertia);
    }

    inertia();
  }

  viewport.addEventListener('pointerup', release);
  viewport.addEventListener('pointercancel', release);
  window.addEventListener('resize', () => centerCard(0));

  /* Init */
  centerCard(0);
  setInterval(scaleCards, 120);

  // Redirect to centered blog detail when clicking #ufc-selected-hero
  document.getElementById('ufc-selected-hero').addEventListener('click', function () {
    let centerCardIdx = cards.findIndex((card) => card.classList.contains('center'));
    if (centerCardIdx === -1) return;
    let link = cards[centerCardIdx].querySelector('.ufc-hero-name-show');
    if (link && link.href) {
      window.location.href = link.href;
    }
  });

  // Go to card's blog link on mouse up if user didn't drag much
  cards.forEach((card, idx) => {
    let pointerDownX = null;
    card.addEventListener('pointerdown', (e) => {
      pointerDownX = e.clientX;
    });
    card.addEventListener('pointerup', (e) => {
      if (pointerDownX === null) return;
      let dx = Math.abs(e.clientX - pointerDownX);
      pointerDownX = null;
      if (dx < 10) {
        let link = card.querySelector('.ufc-hero-name-show');
        if (link && link.href) {
          window.location.href = link.href;
        }
      }
    });
  });
</script>
