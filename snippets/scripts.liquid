<script>
  (function () {
    var STORAGE_KEY = 'ticket_redeem_data';
    var customerLoggedIn = {% if customer %}true{% else %}false{% endif %};
    var customerEmail = {{ customer.email | json }};

    function removeTicketRedeemData() {
      try { localStorage.removeItem(STORAGE_KEY); } catch (e) {}
      try { window.dispatchEvent(new CustomEvent('ticketRedeemDataChange')); } catch (e2) {}
    }

    function isPrizeItemByProperty(item) {
      if (item.properties && (item.properties._prize === '1' || item.properties['_prize'] === '1')) return true;
      if (item.product_type === 'prize') return true;
      return false;
    }

    function productHasPrizeTag(handle) {
      if (!handle) return Promise.resolve(false);
      return fetch('/products/' + encodeURIComponent(handle) + '.js', { headers: { Accept: 'application/json' } })
        .then(function (res) { return res.ok ? res.json() : null; })
        .then(function (product) {
          var tags = product && Array.isArray(product.tags) ? product.tags : [];
          return tags.some(function (t) { return String(t).toLowerCase() === 'prize'; });
        })
        .catch(function () { return false; });
    }

    function getPrizeLineItems(cart) {
      var items = cart.items || [];
      var byProperty = items.filter(isPrizeItemByProperty);
      var needTagCheck = items.filter(function (item) { return !isPrizeItemByProperty(item); });
      if (needTagCheck.length === 0) return Promise.resolve(byProperty);
      var handles = needTagCheck.map(function (item) { return item.handle || item.product_handle; });
      return Promise.all(handles.map(productHasPrizeTag)).then(function (results) {
        var byTag = needTagCheck.filter(function (_, i) { return results[i]; });
        return byProperty.concat(byTag);
      });
    }

    function removePrizeItemsFromCart() {
      fetch('/cart.js', { headers: { Accept: 'application/json' } })
        .then(function (res) { return res.ok ? res.json() : null; })
        .then(function (cart) {
          if (!cart || !cart.items || cart.items.length === 0) return;
          return getPrizeLineItems(cart).then(function (prizeItems) {
            return Promise.all(prizeItems.map(function (item) {
              var key = item.key;
              if (!key) return Promise.resolve();
              return fetch('/cart/change.js', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
                body: JSON.stringify({ id: key, quantity: 0 })
              });
            }));
          });
        })
        .catch(function () {});
    }

    function clearStorageAndRemovePrizeProducts() {
      removeTicketRedeemData();
      removePrizeItemsFromCart();
    }

    if (!customerLoggedIn) {
      clearStorageAndRemovePrizeProducts();
      return;
    }

    try {
      var raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) return;

      var data = null;
      var trimmed = (typeof raw === 'string' ? raw : '').trim();
      if (trimmed.startsWith('{')) {
        data = JSON.parse(trimmed);
      } else if (trimmed.indexOf('.') !== -1) {
        var parts = trimmed.split('.');
        if (parts.length === 3) {
          var payload = parts[1].replace(/-/g, '+').replace(/_/g, '/');
          data = JSON.parse(atob(payload));
        }
      }

      if (!data || typeof data !== 'object') {
        clearStorageAndRemovePrizeProducts();
        return;
      }

      var exp = data.exp != null ? Number(data.exp) : null;
      if (exp != null && !Number.isNaN(exp)) {
        var nowSec = Math.floor(Date.now() / 1000);
        if (exp < nowSec) {
          clearStorageAndRemovePrizeProducts();
          return;
        }
      } else {
        var expireTime = data.expireTime || data.expire_time;
        if (expireTime) {
          var expiry = new Date(expireTime).getTime();
          if (!Number.isNaN(expiry) && Date.now() >= expiry) {
            clearStorageAndRemovePrizeProducts();
            return;
          }
        }
      }

      var tokenEmail = (data.email).toString().trim().toLowerCase();
      var loggedInEmail = (customerEmail || '').toString().trim().toLowerCase();
      if (tokenEmail && loggedInEmail && tokenEmail !== loggedInEmail) {
        clearStorageAndRemovePrizeProducts();
      }
    } catch (_) {
      clearStorageAndRemovePrizeProducts();
    }
  })();
  const basePath = 'https://cdn.shopify.com/static/themes/horizon/placeholders';
  const Theme = {
    placeholders: {
      general: [
        `${basePath}/general-1.png`,
        `${basePath}/general-2.png`,
        `${basePath}/general-3.png`,
        `${basePath}/general-4.png`,
        `${basePath}/general-5.png`,
        `${basePath}/general-6.png`,
        `${basePath}/general-7.png`,
      ],
      product: [`${basePath}/product-ball.png`, `${basePath}/product-cone.png`, `${basePath}/product-cube.png`],
    },
    translations: {
      placeholder_image: `{{ 'content.placeholder_image' | t }}`,
      added: `{{ 'actions.added' | t }}`,
      recipient_form_fields_visible: `{{ 'content.recipient_form_fields_visible' | t }}`,
      recipient_form_fields_hidden: `{{ 'content.recipient_form_fields_hidden' | t }}`,
      recipient_form_error: `{{ 'content.recipient_form_error' | t }}`,
    },
    routes: {
      cart_add_url: '{{ routes.cart_add_url | append: '.js' }}',
      cart_change_url: '{{ routes.cart_change_url }}',
      cart_update_url: '{{ routes.cart_update_url }}',
      cart_url: '{{ routes.cart_url }}',
      predictive_search_url: '{{ routes.predictive_search_url }}',
      search_url: '{{ routes.search_url }}',
    },
    template: {
      name: '{{ template }}',
    },
  };
</script>
