<script>
  (function () {
    var STORAGE_KEY = 'ticket_redeem_data';
    var TICKET_GOLDEN_REDEEM_CODE_KEY = 'ticket_golden_redeem_code';
    var TICKET_PRIZE_DISCOUNT_CODES_KEY = 'ticket_prize_discount_codes';
    var CART_UPDATE_URL_FALLBACK = '{{ routes.cart_update_url }}';
    var customerLoggedIn = {% if customer %}true{% else %}false{% endif %};
    var customerEmail = {{ customer.email | json }};
    var INVALID_TOKEN_MESSAGE = 'Your token is invalid or expired';
    var PRIZE_REMOVED_NOT_LOGGED_IN = {{ 'sections.ticket_redeem.prize_removed_not_logged_in' | t | json }};
    var PRIZE_REMOVED_TICKET_INVALID = {{ 'sections.ticket_redeem.prize_removed_ticket_invalid' | t | json }};
    var PRIZE_REMOVED_NOT_ALLOWED = {{ 'sections.ticket_redeem.prize_removed_not_allowed_for_ticket' | t | json }};
    var PRIZE_REMOVED_MODAL_OK = {{ 'sections.ticket_redeem.prize_removed_ok' | t | json }};

    function getCartUpdateUrl() {
      if (typeof Theme !== 'undefined' && Theme.routes && Theme.routes.cart_update_url) {
        return Theme.routes.cart_update_url;
      }
      return CART_UPDATE_URL_FALLBACK;
    }

    function removeTicketRedeemData() {
      try { localStorage.removeItem(STORAGE_KEY); } catch (e) {}
      try { localStorage.removeItem(TICKET_GOLDEN_REDEEM_CODE_KEY); } catch (e1) {}
      try { window.dispatchEvent(new CustomEvent('ticketRedeemDataChange')); } catch (e2) {}
    }

    function decodeJwtPayload(token) {
      if (!token || typeof token !== 'string') return null;
      try {
        var parts = token.split('.');
        if (parts.length !== 3) return null;
        var payload = parts[1].replace(/-/g, '+').replace(/_/g, '/');
        return JSON.parse(atob(payload));
      } catch (_) {
        return null;
      }
    }

    function jwtPayloadExpired(payload) {
      if (!payload || typeof payload !== 'object') return true;
      var exp = payload.exp != null ? Number(payload.exp) : null;
      if (exp != null && !isNaN(exp)) {
        if (exp < Math.floor(Date.now() / 1000)) return true;
      }
      var expireTime = payload.expireTime || payload.expire_time;
      if (expireTime) {
        var expiry = new Date(expireTime).getTime();
        if (!isNaN(expiry) && Date.now() >= expiry) return true;
      }
      return false;
    }

    /** Skip /apps/redeem/refreshToken when JWT is still valid for at least this many seconds (faster checkout). */
    var CHECKOUT_TOKEN_REFRESH_SKIP_SEC = 300;

    function shouldSkipServerRefreshAtCheckout(token) {
      var payload = decodeJwtPayload(token);
      if (!payload) return false;
      var exp = payload.exp != null ? Number(payload.exp) : null;
      if (exp == null || isNaN(exp)) return false;
      var now = Math.floor(Date.now() / 1000);
      return exp >= now + CHECKOUT_TOKEN_REFRESH_SKIP_SEC;
    }

    function goldenTicketPrimaryDiscountCode(enteredCode, jwtPayload) {
      if (jwtPayload && typeof jwtPayload === 'object') {
        var n = jwtPayload.ticketNumber != null ? jwtPayload.ticketNumber : jwtPayload.ticket_number;
        if (n == null) n = jwtPayload.ticket_code;
        if (n != null && String(n).trim() !== '') return String(n).trim();
      }
      return enteredCode && String(enteredCode).trim() ? String(enteredCode).trim() : '';
    }

    function goldenTicketShipDiscountCode(ticketNum) {
      var t = String(ticketNum).trim();
      var li = t.lastIndexOf('-');
      if (li >= 0 && li < t.length - 1) t = t.slice(li + 1);
      return 'SHIP-' + t;
    }

    function cartCodeListHasCode(list, code) {
      var cl = String(code).toLowerCase();
      return list.some(function (x) {
        return String(x).toLowerCase() === cl;
      });
    }

    /**
     * Applies golden ticket discount codes. Pass prefetchedCart to skip a /cart.js round-trip.
     * Omits section rendering in the POST (checkout path — faster). Resolves to the cart JSON to use next.
     */
    function applyGoldenTicketDiscountsToCart(enteredCode, jwtPayload, prefetchedCart) {
      var primary = goldenTicketPrimaryDiscountCode(enteredCode, jwtPayload);
      if (!primary) return Promise.resolve(prefetchedCart || null);
      var ship = goldenTicketShipDiscountCode(primary);
      var toAdd = ship.toLowerCase() === primary.toLowerCase() ? [primary] : [primary, ship];

      var cartPromise = prefetchedCart
        ? Promise.resolve(prefetchedCart)
        : fetch('/cart.js', { headers: { Accept: 'application/json' } }).then(function (res) {
            return res.ok ? res.json() : null;
          });

      return cartPromise
        .then(function (cart) {
          if (!cart) return null;
          var existing = (cart.discount_codes || []).map(function (d) {
            return d.code;
          });
          var alreadyHasAll = toAdd.every(function (code) {
            return cartCodeListHasCode(existing, code);
          });
          if (alreadyHasAll) {
            try {
              localStorage.setItem(TICKET_PRIZE_DISCOUNT_CODES_KEY, JSON.stringify(toAdd));
            } catch (_) {}
            return cart;
          }
          var merged = existing.slice();
          for (var i = 0; i < toAdd.length; i++) {
            if (!cartCodeListHasCode(merged, toAdd[i])) merged.push(toAdd[i]);
          }
          return fetch(getCartUpdateUrl(), {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
            body: JSON.stringify({ discount: merged.join(',') }),
          })
            .then(function (res) {
              return res.ok ? res.json() : null;
            })
            .then(function (postData) {
              try {
                localStorage.setItem(TICKET_PRIZE_DISCOUNT_CODES_KEY, JSON.stringify(toAdd));
              } catch (_) {}
              try {
                document.dispatchEvent(new CustomEvent('cart:refresh'));
              } catch (_) {}
              if (postData && (postData.token || postData.items)) {
                return postData;
              }
              return fetch('/cart.js', { headers: { Accept: 'application/json' } }).then(function (r) {
                return r.ok ? r.json() : cart;
              });
            });
        })
        .catch(function () {
          return prefetchedCart || null;
        });
    }

    /**
     * Checkout: optionally refresh ticket (skipped when JWT still valid for several minutes),
     * then if the cart has a prize and ticket is golden + in period, apply discount codes.
     * options.initialCart — reuse caller's cart (saves /cart.js). Returns cart + token for pre-checkout when possible.
     */
    function prepareCheckoutGoldenTicketDiscounts(options) {
      options = options || {};
      var initialCart = options.initialCart || null;

      var cartPromise = initialCart
        ? Promise.resolve(initialCart)
        : fetch('/cart.js', { headers: { Accept: 'application/json' } }).then(function (res) {
            return res.ok ? res.json() : null;
          });

      return cartPromise
        .then(function (cart) {
          if (!cart) return { ok: true, noPrize: true };
          return getPrizeLineItems(cart).then(function (prizeItems) {
            if (prizeItems.length === 0) {
              return removeTicketPrizeDiscountsFromCart().then(function () {
                return { ok: true, noPrize: true };
              });
            }
            var token = getTokenFromStorage();
            if (!token) {
              return { ok: false, needTicket: true };
            }

            function applyGoldenDiscountsAndBuildPrepResult(cartSnapshot) {
              var token2 = getTokenFromStorage();
              if (!token2) {
                return { ok: false, needTicket: true };
              }
              var payload = decodeJwtPayload(token2);
              if (!payload || jwtPayloadExpired(payload)) {
                return { ok: false, invalidToken: true };
              }
              var tt = (payload.ticketType != null && payload.ticketType !== '')
                ? String(payload.ticketType).toLowerCase()
                : payload.ticket_type != null && payload.ticket_type !== ''
                  ? String(payload.ticket_type).toLowerCase()
                  : '';
              if (tt !== 'golden') {
                return {
                  ok: true,
                  hadPrize: true,
                  cart: cartSnapshot,
                  token: token2,
                };
              }
              var enteredCode = '';
              try {
                enteredCode = localStorage.getItem(TICKET_GOLDEN_REDEEM_CODE_KEY) || '';
              } catch (_) {}
              return applyGoldenTicketDiscountsToCart(enteredCode, payload, cartSnapshot).then(function (cartOut) {
                return {
                  ok: true,
                  hadPrize: true,
                  cart: cartOut || cartSnapshot,
                  token: getTokenFromStorage() || token2,
                };
              });
            }

            /** skipPrizeRecheck: after JWT skip-refresh path cart is unchanged — avoids a second slow prize-tag scan. */
            function finishWithCartSnapshot(cartSnapshot, skipPrizeRecheck) {
              if (!cartSnapshot) return Promise.resolve({ ok: false, invalidToken: true });
              if (skipPrizeRecheck) {
                return Promise.resolve(applyGoldenDiscountsAndBuildPrepResult(cartSnapshot));
              }
              return getPrizeLineItems(cartSnapshot).then(function (prizeAfter) {
                if (prizeAfter.length === 0) {
                  return removeTicketPrizeDiscountsFromCart().then(function () {
                    return { ok: true, noPrize: true };
                  });
                }
                return Promise.resolve(applyGoldenDiscountsAndBuildPrepResult(cartSnapshot));
              });
            }

            function afterRefreshResult(result) {
              var handled = handleRedeemApiResponse(result.response, result.data);
              if (handled && result.response && result.response.status === 401) {
                return { ok: false, invalidToken: true };
              }
              return fetch('/cart.js', { headers: { Accept: 'application/json' } })
                .then(function (r2) {
                  return r2.ok ? r2.json() : null;
                })
                .then(finishWithCartSnapshot);
            }

            if (shouldSkipServerRefreshAtCheckout(token)) {
              var plQuick = decodeJwtPayload(token);
              if (!plQuick || jwtPayloadExpired(plQuick)) {
                return Promise.resolve({ ok: false, invalidToken: true });
              }
              return finishWithCartSnapshot(cart, true);
            }

            return fetch(REFRESH_TOKEN_URL, {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest',
                Accept: 'application/json',
              },
              body: JSON.stringify({ token: token }),
            })
              .then(function (res) {
                return res.json().catch(function () {
                  return {};
                }).then(function (data) {
                  return { response: res, data: data };
                });
              })
              .then(afterRefreshResult);
          });
        })
        .catch(function () {
          return { ok: true };
        });
    }

    function isPrizeItemByProperty(item) {
      if (item.properties && (item.properties._prize === '1' || item.properties['_prize'] === '1')) return true;
      if (item.product_type === 'prize') return true;
      return false;
    }

    function productHasPrizeTag(handle) {
      if (!handle) return Promise.resolve(false);
      return fetch('/products/' + encodeURIComponent(handle) + '.js', { headers: { Accept: 'application/json' } })
        .then(function (res) { return res.ok ? res.json() : null; })
        .then(function (product) {
          var tags = product && Array.isArray(product.tags) ? product.tags : [];
          return tags.some(function (t) { return String(t).toLowerCase() === 'prize'; });
        })
        .catch(function () { return false; });
    }

    function getPrizeLineItems(cart) {
      var items = cart.items || [];
      var byProperty = items.filter(isPrizeItemByProperty);
      var needTagCheck = items.filter(function (item) { return !isPrizeItemByProperty(item); });
      if (needTagCheck.length === 0) return Promise.resolve(byProperty);
      var handles = needTagCheck.map(function (item) { return item.handle || item.product_handle; });
      return Promise.all(handles.map(productHasPrizeTag)).then(function (results) {
        var byTag = needTagCheck.filter(function (_, i) { return results[i]; });
        return byProperty.concat(byTag);
      });
    }

    function showPrizeRemovedFromCartModal(message) {
      if (!message || typeof message !== 'string') return;
      var dialog = document.createElement('dialog');
      dialog.setAttribute('aria-modal', 'true');
      dialog.setAttribute('aria-labelledby', 'prize-removed-header-title prize-removed-body');
      dialog.className = 'prize-claim-modal color-scheme-db578fa1-da9c-48c2-a278-c672d942f928';
      var okLabel = PRIZE_REMOVED_MODAL_OK || 'OK';
      dialog.innerHTML =
        '<div class="prize-claim-modal__backdrop" data-prize-removed-close></div>' +
        '<div class="ticket-redeem__modal-content">' +
        '<div class="ticket-redeem__modal-header">' +
        '<h2 id="prize-removed-header-title" class="ticket-redeem__modal-header-title"></h2>' +
        '</div>' +
        '<div class="ticket-redeem__modal-body">' +
        '<p id="prize-removed-body" class="prize-claim-modal__message"></p>' +
        '<div class="prize-claim-modal__actions">' +
        '<button type="button" class="button button--primary" data-prize-removed-close></button>' +
        '</div></div></div>';
      var headerEl = dialog.querySelector('#prize-removed-header-title');
      var bodyEl = dialog.querySelector('#prize-removed-body');
      var okBtn = dialog.querySelector('[data-prize-removed-close].button');
      var headerTitle =
        typeof window !== 'undefined' && window.__themeTicketModalAlertTitle
          ? String(window.__themeTicketModalAlertTitle)
          : 'Ticket alert';
      if (headerEl) headerEl.textContent = headerTitle;
      if (bodyEl) bodyEl.textContent = message;
      if (okBtn) okBtn.textContent = okLabel;
      var style = document.createElement('style');
      style.textContent =
        '.prize-claim-modal { position: fixed; inset: 0; width: 100%; height: 100%; border: none; padding: 0; background: transparent; }' +
        '.prize-claim-modal::backdrop { background: rgba(0, 0, 0, 0.5); }' +
        '.prize-claim-modal__backdrop { position: absolute; inset: 0; }' +
        '.prize-claim-modal__actions { display: flex; gap: 0.5rem; justify-content: flex-end; }';
      dialog.appendChild(style);
      function close() {
        try {
          dialog.close();
        } catch (_) {}
        dialog.remove();
      }
      dialog.querySelectorAll('[data-prize-removed-close]').forEach(function (el) {
        el.addEventListener('click', close);
      });
      var backdrop = dialog.querySelector('.prize-claim-modal__backdrop');
      if (backdrop) backdrop.addEventListener('click', close);
      dialog.addEventListener('click', function (e) {
        if (e.target === dialog) close();
      });
      document.body.appendChild(dialog);
      try {
        dialog.showModal();
      } catch (_) {}
    }

    /**
     * @param {string} [reasonMessage] If set and at least one prize line was removed, shows explain modal after removal.
     */
    function removePrizeItemsFromCart(reasonMessage) {
      var msg = typeof reasonMessage === 'string' && reasonMessage.trim() ? reasonMessage : '';
      return fetch('/cart.js', { headers: { Accept: 'application/json' } })
        .then(function (res) { return res.ok ? res.json() : null; })
        .then(function (cart) {
          if (!cart || !cart.items || cart.items.length === 0) return 0;
          return getPrizeLineItems(cart).then(function (prizeItems) {
            if (!prizeItems || prizeItems.length === 0) return 0;
            return Promise.all(
              prizeItems.map(function (item) {
                var key = item.key;
                if (!key) return Promise.resolve();
                return fetch('/cart/change.js', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
                  body: JSON.stringify({ id: key, quantity: 0 })
                });
              })
            ).then(function () {
              try {
                document.dispatchEvent(new CustomEvent('cart:refresh'));
              } catch (_) {}
              if (msg) showPrizeRemovedFromCartModal(msg);
              return prizeItems.length;
            });
          });
        })
        .catch(function () {
          return 0;
        });
    }

    /**
     * Removes discount codes that were auto-applied for golden-ticket + prize flow (see ticket_input).
     * Clears TICKET_PRIZE_DISCOUNT_CODES_KEY after updating the cart.
     */
    function removeTicketPrizeDiscountsFromCart() {
      var raw;
      try {
        raw = localStorage.getItem(TICKET_PRIZE_DISCOUNT_CODES_KEY);
      } catch (e) {
        return Promise.resolve();
      }
      if (!raw || !String(raw).trim()) {
        return Promise.resolve();
      }
      var toRemove;
      try {
        toRemove = JSON.parse(raw);
      } catch (e2) {
        try { localStorage.removeItem(TICKET_PRIZE_DISCOUNT_CODES_KEY); } catch (e3) {}
        return Promise.resolve();
      }
      if (!Array.isArray(toRemove) || toRemove.length === 0) {
        try { localStorage.removeItem(TICKET_PRIZE_DISCOUNT_CODES_KEY); } catch (e4) {}
        return Promise.resolve();
      }
      var removeLower = toRemove.map(function (c) { return String(c).toLowerCase(); });
      return fetch('/cart.js', { headers: { Accept: 'application/json' } })
        .then(function (res) { return res.ok ? res.json() : null; })
        .then(function (cart) {
          if (!cart) {
            try { localStorage.removeItem(TICKET_PRIZE_DISCOUNT_CODES_KEY); } catch (e5) {}
            return;
          }
          var existing = (cart.discount_codes || []).map(function (d) { return d.code; });
          var kept = existing.filter(function (code) {
            return removeLower.indexOf(String(code).toLowerCase()) === -1;
          });
          var body = { discount: kept.join(',') };
          var sectionEl = document.querySelector('cart-items-component');
          if (sectionEl && sectionEl.dataset && sectionEl.dataset.sectionId) {
            body.sections = [sectionEl.dataset.sectionId];
          }
          return fetch(getCartUpdateUrl(), {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
            body: JSON.stringify(body),
          }).then(function () {
            try { localStorage.removeItem(TICKET_PRIZE_DISCOUNT_CODES_KEY); } catch (e6) {}
            try { document.dispatchEvent(new CustomEvent('cart:refresh')); } catch (e7) {}
          });
        })
        .catch(function () {});
    }

    /** If the cart has no prize lines, strip ticket-linked discount codes (before checkout). */
    function syncTicketPrizeDiscountsBeforeCheckout() {
      return fetch('/cart.js', { headers: { Accept: 'application/json' } })
        .then(function (res) { return res.ok ? res.json() : null; })
        .then(function (cart) {
          if (!cart) return;
          return getPrizeLineItems(cart).then(function (prizeItems) {
            if (prizeItems.length > 0) return;
            return removeTicketPrizeDiscountsFromCart();
          });
        })
        .catch(function () {});
    }

    function clearStorageAndRemovePrizeProducts(reasonMessage) {
      removeTicketRedeemData();
      removePrizeItemsFromCart(reasonMessage)
        .then(function () { return removeTicketPrizeDiscountsFromCart(); })
        .catch(function () {});
    }

    /** Allowed prize variant ids from token payload (myPrize or reservedPrizes[].prizeId). */
    function getAllowedPrizeVariantIds(token) {
      if (!token || typeof token !== 'string') return [];
      try {
        var trimmed = token.trim();
        if (trimmed.startsWith('{')) {
          var parsed = JSON.parse(trimmed);
          if (parsed && typeof parsed.token === 'string') trimmed = parsed.token;
        }
        var parts = trimmed.split('.');
        if (parts.length !== 3) return [];
        var payload = parts[1].replace(/-/g, '+').replace(/_/g, '/');
        var data = JSON.parse(atob(payload));
        if (!data || typeof data !== 'object') return [];
        var ids = [];
        var myPrize = data.myPrize != null ? data.myPrize : data.my_prize;
        if (myPrize != null && myPrize !== '') ids.push(String(myPrize).trim());
        var list = data.reservedPrizes || data.reserved_prizes;
        if (Array.isArray(list)) {
          list.forEach(function (p) {
            var id = p.prizeId != null ? p.prizeId : p.prize_id;
            if (id != null && id !== '') ids.push(String(id).trim());
          });
        }
        return ids;
      } catch (_) {
        return [];
      }
    }

    /** Remove from cart any prize item whose variant_id is not in the token's allowed list. */
    function removePrizeItemsNotInToken(token) {
      var allowed = getAllowedPrizeVariantIds(token);
      fetch('/cart.js', { headers: { Accept: 'application/json' } })
        .then(function (res) { return res.ok ? res.json() : null; })
        .then(function (cart) {
          if (!cart || !cart.items || cart.items.length === 0) return;
          return getPrizeLineItems(cart).then(function (prizeItems) {
            var toRemove = prizeItems.filter(function (item) {
              var vid = String(item.variant_id != null ? item.variant_id : item.id || '').trim();
              return vid && allowed.indexOf(vid) === -1;
            });
            if (toRemove.length === 0) return;
            return Promise.all(
              toRemove.map(function (item) {
                var key = item.key;
                if (!key) return Promise.resolve();
                return fetch('/cart/change.js', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
                  body: JSON.stringify({ id: key, quantity: 0 })
                });
              })
            ).then(function () {
              try {
                document.dispatchEvent(new CustomEvent('cart:refresh'));
              } catch (_) {}
              showPrizeRemovedFromCartModal(PRIZE_REMOVED_NOT_ALLOWED);
            });
          });
        })
        .catch(function () {});
    }

    function getTokenFromStorage() {
      try {
        var raw = localStorage.getItem(STORAGE_KEY);
        if (!raw || typeof raw !== 'string') return null;
        var trimmed = raw.trim();
        if (!trimmed) return null;
        if (trimmed.startsWith('{')) {
          var parsed = JSON.parse(trimmed);
          if (parsed && typeof parsed.token === 'string') return parsed.token.trim();
          return null;
        }
        return trimmed;
      } catch (_) {
        return null;
      }
    }

    var REFRESH_TOKEN_URL = '/apps/redeem/refreshToken';

    function runTokenCheck() {
      if (!customerLoggedIn) {
        clearStorageAndRemovePrizeProducts(PRIZE_REMOVED_NOT_LOGGED_IN);
        return;
      }
      var token = getTokenFromStorage();
      if (!token) return;

      fetch(REFRESH_TOKEN_URL, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-Requested-With': 'XMLHttpRequest',
          Accept: 'application/json'
        },
        body: JSON.stringify({ token: token })
      })
        .then(function (res) {
          return res.json().catch(function () { return {}; }).then(function (data) {
            return { response: res, data: data };
          });
        })
        .then(function (result) {
          handleRedeemApiResponse(result.response, result.data);
        })
        .catch(function () {});
    }

    function performTicketLogout() {
      clearStorageAndRemovePrizeProducts(PRIZE_REMOVED_TICKET_INVALID);
    }

    function applyRedeemTokenAndSync(newToken) {
      if (!newToken || typeof newToken !== 'string' || !newToken.trim()) return;
      try {
        localStorage.setItem(STORAGE_KEY, newToken.trim());
        try { window.dispatchEvent(new CustomEvent('ticketRedeemDataChange')); } catch (_) {}
        if (typeof window.refreshPrizeProductState === 'function') {
          window.refreshPrizeProductState();
        }
        removePrizeItemsNotInToken(newToken);
      } catch (_) {}
    }

    function handleRedeemApiResponse(response, data) {
      var message = (data && (data.message || data.error || data.text || '')).toString().trim();
      if (response && response.status === 401 && message.indexOf(INVALID_TOKEN_MESSAGE) !== -1) {
        performTicketLogout();
        return true;
      }
      if (response && response.ok && data && typeof data.token === 'string' && data.token.trim()) {
        applyRedeemTokenAndSync(data.token);
        return true;
      }
      return false;
    }

    window.performTicketLogout = performTicketLogout;
    window.applyRedeemTokenAndSync = applyRedeemTokenAndSync;
    window.handleRedeemApiResponse = handleRedeemApiResponse;
    window.showPrizeRemovedFromCartModal = showPrizeRemovedFromCartModal;
    window.removePrizeItemsFromCart = removePrizeItemsFromCart;
    window.__themePrizeRemovedMessages = {
      noValidTicket: {{ 'sections.ticket_redeem.prize_removed_no_valid_ticket' | t | json }}
    };
    window.removeTicketPrizeDiscountsFromCart = removeTicketPrizeDiscountsFromCart;
    window.syncTicketPrizeDiscountsBeforeCheckout = syncTicketPrizeDiscountsBeforeCheckout;
    window.prepareCheckoutGoldenTicketDiscounts = prepareCheckoutGoldenTicketDiscounts;

    var cartCheckoutDiscountSyncBypass = false;
    document.addEventListener(
      'submit',
      function (e) {
        if (cartCheckoutDiscountSyncBypass) {
          cartCheckoutDiscountSyncBypass = false;
          return;
        }
        var form = e.target;
        if (!form || form.id !== 'cart-form') return;
        var sub = e.submitter;
        if (!sub || sub.getAttribute('name') !== 'checkout') return;
        e.preventDefault();
        e.stopPropagation();
        var prepPromise =
          typeof window.prepareCheckoutGoldenTicketDiscounts === 'function'
            ? window.prepareCheckoutGoldenTicketDiscounts()
            : syncTicketPrizeDiscountsBeforeCheckout();
        prepPromise
          .then(function (prep) {
            if (prep && prep.invalidToken) {
              try {
                window.alert('Your ticket is invalid or expired. Please redeem again.');
              } catch (_) {}
              return;
            }
            cartCheckoutDiscountSyncBypass = true;
            if (typeof form.requestSubmit === 'function') {
              form.requestSubmit(sub);
            } else {
              sub.click();
            }
          })
          .catch(function () {
            cartCheckoutDiscountSyncBypass = true;
            if (typeof form.requestSubmit === 'function') {
              form.requestSubmit(sub);
            } else {
              sub.click();
            }
          });
      },
      true
    );

    function runAfterLoad() {
      if (typeof requestIdleCallback !== 'undefined') {
        requestIdleCallback(function () { runTokenCheck(); }, { timeout: 100 });
      } else {
        setTimeout(runTokenCheck, 0);
      }
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', runAfterLoad);
    } else {
      runAfterLoad();
    }
  })();
  const basePath = 'https://cdn.shopify.com/static/themes/horizon/placeholders';
  const Theme = {
    placeholders: {
      general: [
        `${basePath}/general-1.png`,
        `${basePath}/general-2.png`,
        `${basePath}/general-3.png`,
        `${basePath}/general-4.png`,
        `${basePath}/general-5.png`,
        `${basePath}/general-6.png`,
        `${basePath}/general-7.png`,
      ],
      product: [`${basePath}/product-ball.png`, `${basePath}/product-cone.png`, `${basePath}/product-cube.png`],
    },
    translations: {
      placeholder_image: `{{ 'content.placeholder_image' | t }}`,
      added: `{{ 'actions.added' | t }}`,
      recipient_form_fields_visible: `{{ 'content.recipient_form_fields_visible' | t }}`,
      recipient_form_fields_hidden: `{{ 'content.recipient_form_fields_hidden' | t }}`,
      recipient_form_error: `{{ 'content.recipient_form_error' | t }}`,
    },
    routes: {
      cart_add_url: '{{ routes.cart_add_url | append: '.js' }}',
      cart_change_url: '{{ routes.cart_change_url }}',
      cart_update_url: '{{ routes.cart_update_url }}',
      cart_url: '{{ routes.cart_url }}',
      predictive_search_url: '{{ routes.predictive_search_url }}',
      search_url: '{{ routes.search_url }}',
    },
    template: {
      name: '{{ template }}',
    },
  };
</script>
