<div class="group-video">
  <div class="featured-video" id="featured-video-container">
    {{ slides[0] }}
  </div>
  {% render 'resource-list-carousel', slides: slides, slide_count: '4', settings: settings %}
</div>
<script>
  document.querySelectorAll('.youtube-video-dashboard deferred-media').forEach((item) => {
    item.addEventListener('click', () => {
      const featuredContainer = document.getElementById('featured-video-container');

      // Replace featured video HTML with the clicked one
      featuredContainer.innerHTML = item.dataset.video;

      // Re-initialize any deferred-media behavior
      const deferred = featuredContainer.querySelector('deferred-media');
      if (deferred && deferred.loadContent) deferred.loadContent();
    });
  });
</script>

<div class="carousel-video" data-embed='<iframe src="https://www.youtube.com/embed/VIDEO_ID?autoplay=1&.."></iframe>'>
  <!-- inside here, show thumbnail or a deferred-media image/preview -->
  <!-- Optionally, render the deferred-media element if you want but do not place a live iframe there -->
</div>
