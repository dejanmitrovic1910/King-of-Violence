{% liquid
    assign block_settings = block.settings
    assign ticket_prize_modal_cs = settings.prize_modal_color_scheme | default: 'scheme-1'
    assign response_id = 'TicketRedeemResponse-' | append: block.id
    assign modal_id = 'TicketRedeemModal-' | append: block.id
    assign login_modal_id = 'TicketLoginRequiredModal-' | append: block.id
    assign modal_input_id = 'TicketRedeemModalInput-' | append: block.id
  %}
  
  {% liquid
    assign align_desktop = block_settings.alignment_desktop | default: 'left'
    assign align_mobile = block_settings.alignment_mobile | default: 'left'
    assign align_items_desktop = 'flex-start'
    assign align_items_mobile = 'flex-start'
    if align_desktop == 'center'
      assign align_items_desktop = 'center'
    elsif align_desktop == 'right'
      assign align_items_desktop = 'flex-end'
    endif
    if align_mobile == 'center'
      assign align_items_mobile = 'center'
    elsif align_mobile == 'right'
      assign align_items_mobile = 'flex-end'
    endif
  %}
  <div
    class="ticket-redeem spacing-style {{ block_settings.identifier }}"
    data-ticket-block-id="{{ block.id }}"
    data-section-id="{{ section.id }}"
    data-customer-logged-in="{% if customer %}true{% else %}false{% endif %}"
    data-customer-email="{% if customer %}{{ customer.email | escape }}{% endif %}"
    style="
      {% render 'spacing-style', settings: block_settings %}
      {% render 'border-override', settings: block_settings %}
      --ticket-align-desktop: {{ align_desktop }};
      --ticket-align-mobile: {{ align_mobile }};
      --ticket-align-items-desktop: {{ align_items_desktop }};
      --ticket-align-items-mobile: {{ align_items_mobile }};
    "
    {{ block.shopify_attributes }}
  >
    <div class="ticket-redeem__inner section-content-wrapper">
      {% if block_settings.heading != blank %}
        <h2 class="ticket-redeem__heading {{ block_settings.heading_size }}">
          {{ block_settings.heading }}
        </h2>
      {% endif %}
  
      <div class="ticket-redeem__form-wrapper" data-ticket-redeem>
        {% comment %} State: no ticket in localStorage or logged out — show locked image (if set) and "Input ticket" button {% endcomment %}
        <div class="ticket-redeem__state ticket-redeem__state--input" data-ticket-state-input hidden>
          <div class="ticket-redeem__ticket-display">
            <span class="ticket-redeem__locked-image-wrap" data-ticket-locked-image-wrap hidden>
              <img class="ticket-redeem__ticket-image ticket-redeem__locked-image" data-ticket-locked-image alt="" width="400" height="auto">
            </span>
            <button
              type="button"
              class="button button--primary ticket-redeem__trigger"
              data-ticket-open-modal
              aria-haspopup="dialog"
              aria-controls="{{ modal_id }}"
            >
              {{ block_settings.input_ticket_label }}
            </button>
          </div>
        </div>
  
        {% comment %} State: ticket in localStorage — show ticket type image, name, and logout {% endcomment %}
        <div class="ticket-redeem__state ticket-redeem__state--logged-in" data-ticket-state-logged-in hidden>
          <div class="ticket-redeem__ticket-display">
            <div class="ticket-redeem__ticket-content" data-ticket-type-content>
              <span class="ticket-redeem__ticket-image-wrap" data-ticket-type-image-wrap hidden>
                <img class="ticket-redeem__ticket-image" data-ticket-type-image alt="" width="400" height="auto">
              </span>
            </div>
            <button type="button" class="button button--secondary ticket-redeem__logout" data-ticket-logout>
              {{ block_settings.logout_label }}
            </button>
          </div>
        </div>
  
        {% comment %} Inline response message (e.g. after submit in modal) {% endcomment %}
        <div
          id="{{ response_id }}"
          class="ticket-redeem__response hidden"
          role="status"
          aria-live="polite"
          data-ticket-redeem-response
        >
          <p class="ticket-redeem__response-text"></p>
        </div>
      </div>
    </div>
  
    {% comment %} Modal: one input field for ticket code (inside wrapper so script can find it) {% endcomment %}
    <dialog
      id="{{ modal_id }}"
      class="ticket-redeem__modal"
      data-ticket-modal
      aria-labelledby="{{ modal_id }}-header-title {{ modal_id }}-title"
      aria-modal="true"
    >
      <div class="ticket-redeem__modal-backdrop" data-ticket-modal-close></div>
      <div class="ticket-redeem__modal-content">
        <div class="ticket-redeem__modal-header">
          <h2 id="{{ modal_id }}-header-title" class="ticket-redeem__modal-header-title">
            {{ 'sections.ticket_redeem.modal_alert_title' | t }}
          </h2>
        </div>
        <div class="ticket-redeem__modal-body">
        <h3 id="{{ modal_id }}-title" class="ticket-redeem__modal-title">
          {{ block_settings.modal_title }}
        </h3>
        <form class="ticket-redeem__modal-form" data-ticket-redeem-form>
          <input type="hidden" name="form_type" value="ticket_redeem">
          <label class="visually-hidden" for="{{ modal_input_id }}">
            {{ 'sections.ticket_redeem.code_label' | t }}
          </label>
          <input
            type="text"
            id="{{ modal_input_id }}"
            class="ticket-redeem__input ticket-redeem__modal-input"
            name="code"
            autocomplete="off"
            placeholder="{{ block_settings.placeholder }}"
            required
            data-ticket-redeem-input
          >
          <div class="ticket-redeem__modal-actions">
            <button type="submit" class="button button--primary ticket-redeem__submit" data-ticket-redeem-submit>
              <span class="ticket-redeem__submit-text">{{ block_settings.button_label }}</span>
              <span class="ticket-redeem__submit-loading hidden" aria-hidden="true">{{ 'sections.ticket_redeem.submitting' | t }}</span>
            </button>
            <button type="button" class="button button--secondary" data-ticket-modal-close>
              {{ 'sections.ticket_redeem.close' | t }}
            </button>
          </div>
        </form>
        <div class="ticket-redeem__modal-response hidden" data-ticket-modal-response role="status" aria-live="polite">
          <p class="ticket-redeem__response-text" data-ticket-modal-response-text></p>
        </div>
        </div>
      </div>
    </dialog>

    {% comment %} Modal: log in required (shown when guest clicks Input ticket) {% endcomment %}
    <dialog
      id="{{ login_modal_id }}"
      class="ticket-redeem__modal ticket-redeem__modal--login-required"
      data-ticket-login-modal
      aria-labelledby="{{ login_modal_id }}-header-title {{ login_modal_id }}-title"
      aria-modal="true"
    >
      <div class="ticket-redeem__modal-backdrop" data-ticket-login-modal-close></div>
      <div class="ticket-redeem__modal-content">
        <div class="ticket-redeem__modal-header">
          <h2 id="{{ login_modal_id }}-header-title" class="ticket-redeem__modal-header-title">
            {{ 'sections.ticket_redeem.modal_alert_title' | t }}
          </h2>
        </div>
        <div class="ticket-redeem__modal-body">
        <h3 id="{{ login_modal_id }}-title" class="ticket-redeem__modal-title">
          {{ 'sections.ticket_redeem.login_required_title' | t | default: 'Log in required' }}
        </h3>
        <p class="ticket-redeem__login-message">
          {{ 'sections.ticket_redeem.login_required_message' | t | default: 'Log in to get the prize.' }}
        </p>
        <div class="ticket-redeem__modal-actions">
          <a href="{{ routes.account_login_url }}" class="button button--primary">{{ 'sections.ticket_redeem.log_in' | t | default: 'Log in' }}</a>
          <button type="button" class="button button--secondary" data-ticket-login-modal-close>
            {{ 'sections.ticket_redeem.close' | t }}
          </button>
        </div>
        </div>
      </div>
    </dialog>
  </div>
  
  <script>
    (function () {
      const STORAGE_KEY = 'ticket_redeem_data';
      const TICKET_GOLDEN_REDEEM_CODE_KEY = 'ticket_golden_redeem_code';
      const MODAL_ALERT_TITLE = {{ 'sections.ticket_redeem.modal_alert_title' | t | json }};
      const PRIZE_MODAL_COLOR_CLASS = {{ 'color-' | append: ticket_prize_modal_cs | json }};
      const PRIZE_REMOVED_TICKET_LOGOUT = {{ 'sections.ticket_redeem.prize_removed_ticket_logout' | t | json }};
      const LOGOUT_FAILED_TITLE = {{ 'sections.ticket_redeem.logout_failed_title' | t | json }};
      const LOGOUT_FAILED_MESSAGE = {{ 'sections.ticket_redeem.logout_failed_message' | t | json }};
      const wrapper = document.querySelector('[data-ticket-block-id="{{ block.id }}"]');
      if (!wrapper) return;
  
      const stateInput = wrapper.querySelector('[data-ticket-state-input]');
      const stateLoggedIn = wrapper.querySelector('[data-ticket-state-logged-in]');
      const openModalBtn = wrapper.querySelector('[data-ticket-open-modal]');
      const logoutBtn = wrapper.querySelector('[data-ticket-logout]');
      const modal = wrapper.querySelector('[data-ticket-modal]');
      const loginModal = wrapper.querySelector('[data-ticket-login-modal]');
      const modalCloseBtns = wrapper.querySelectorAll('[data-ticket-modal-close]');
      const loginModalCloseBtns = wrapper.querySelectorAll('[data-ticket-login-modal-close]');
      const modalForm = wrapper.querySelector('[data-ticket-redeem-form]');
      const modalInput = wrapper.querySelector('[data-ticket-redeem-input]');
      const submitBtn = wrapper.querySelector('[data-ticket-redeem-submit]');
      const submitText = wrapper.querySelector('.ticket-redeem__submit-text');
      const submitLoading = wrapper.querySelector('.ticket-redeem__submit-loading');
      const modalResponse = wrapper.querySelector('[data-ticket-modal-response]');
      const modalResponseText = wrapper.querySelector('[data-ticket-modal-response-text]');
      const ticketTypeImageWrap = wrapper.querySelector('[data-ticket-type-image-wrap]');
      const ticketTypeImage = wrapper.querySelector('[data-ticket-type-image]');
      const lockedImageWrap = wrapper.querySelector('[data-ticket-locked-image-wrap]');
      const lockedImage = wrapper.querySelector('[data-ticket-locked-image]');

      const imageByType = {
        golden: {% if block_settings.golden_ticket_image != blank %}{{ block_settings.golden_ticket_image | image_url: width: 800 | json }}{% else %}null{% endif %},
        platinum: {% if block_settings.platinum_ticket_image != blank %}{{ block_settings.platinum_ticket_image | image_url: width: 800 | json }}{% else %}null{% endif %}
      };
      const defaultImageUrl = {% if block_settings.default_ticket_image != blank %}{{ block_settings.default_ticket_image | image_url: width: 800 | json }}{% else %}null{% endif %};
  
      /** Returns the token string from localStorage (ticket_redeem_data stores only the token). */
      function getStored() {
        try {
          const raw = localStorage.getItem(STORAGE_KEY);
          if (!raw || typeof raw !== 'string') return null;
          const trimmed = raw.trim();
          return trimmed || null;
        } catch (_) {
          return null;
        }
      }

      /** Decode JWT payload for UI (ticketType, exp, image). Returns null if not a valid JWT. */
      function decodeTokenPayload(token) {
        if (!token || typeof token !== 'string') return null;
        try {
          const parts = token.split('.');
          if (parts.length !== 3) return null;
          const payload = parts[1].replace(/-/g, '+').replace(/_/g, '/');
          return JSON.parse(atob(payload));
        } catch (_) {
          return null;
        }
      }

      function isPayloadExpired(payload) {
        if (!payload || typeof payload !== 'object') return true;
        const exp = payload.exp != null ? Number(payload.exp) : null;
        if (exp != null && !Number.isNaN(exp)) {
          const now = Math.floor(Date.now() / 1000);
          if (exp < now) return true;
        }
        const expireTime = payload.expireTime || payload.expire_time;
        if (expireTime) {
          const expiry = new Date(expireTime).getTime();
          if (!Number.isNaN(expiry) && Date.now() >= expiry) return true;
        }
        return false;
      }

      /** Persist redeem code for golden tickets (used at checkout to build discount codes). Cleared for non-golden. */
      function syncGoldenRedeemCodeStorage(enteredCode, token) {
        const payload = decodeTokenPayload(token);
        if (!payload || typeof payload !== 'object') {
          try { localStorage.removeItem(TICKET_GOLDEN_REDEEM_CODE_KEY); } catch (_) {}
          return;
        }
        const ticketType = (payload.ticketType != null && payload.ticketType !== '')
          ? String(payload.ticketType).toLowerCase()
          : (payload.ticket_type != null && payload.ticket_type !== '')
            ? String(payload.ticket_type).toLowerCase()
            : '';
        try {
          if (ticketType === 'golden') {
            localStorage.setItem(TICKET_GOLDEN_REDEEM_CODE_KEY, String(enteredCode).trim());
          } else {
            localStorage.removeItem(TICKET_GOLDEN_REDEEM_CODE_KEY);
          }
        } catch (_) {}
      }

      /** Save only the token string to localStorage. */
      function setStored(token) {
        try {
          if (typeof token !== 'string' || !token.trim()) return;
          localStorage.setItem(STORAGE_KEY, token.trim());
          try { window.dispatchEvent(new CustomEvent('ticketRedeemDataChange')); } catch (_) {}
        } catch (_) {}
      }

      function clearStored() {
        localStorage.removeItem(STORAGE_KEY);
        try { localStorage.removeItem(TICKET_GOLDEN_REDEEM_CODE_KEY); } catch (_) {}
        try { window.dispatchEvent(new CustomEvent('ticketRedeemDataChange')); } catch (_) {}
      }

      function getTokenFromStored() {
        return getStored();
      }

      function showLogoutFailedModal() {
        const dialog = document.createElement('dialog');
        dialog.setAttribute('aria-modal', 'true');
        dialog.setAttribute('aria-labelledby', 'ticket-logout-failed-header-title ticket-logout-failed-title');
        dialog.className = 'ticket-redeem__modal ' + PRIZE_MODAL_COLOR_CLASS;
        dialog.innerHTML =
          '<div class="ticket-redeem__modal-backdrop" data-ticket-logout-close></div>' +
          '<div class="ticket-redeem__modal-content">' +
          '<div class="ticket-redeem__modal-header">' +
          '<h2 id="ticket-logout-failed-header-title" class="ticket-redeem__modal-header-title"></h2>' +
          '</div>' +
          '<div class="ticket-redeem__modal-body">' +
          '<h3 id="ticket-logout-failed-title" class="ticket-redeem__modal-title"></h3>' +
          '<p class="ticket-redeem__login-message" data-ticket-logout-failed-body></p>' +
          '<div class="ticket-redeem__modal-actions"><button type="button" class="button button--primary" data-ticket-logout-close>OK</button></div>' +
          '</div></div>';
        const headerEl = dialog.querySelector('#ticket-logout-failed-header-title');
        const titleEl = dialog.querySelector('#ticket-logout-failed-title');
        const bodyEl = dialog.querySelector('[data-ticket-logout-failed-body]');
        if (headerEl) headerEl.textContent = MODAL_ALERT_TITLE;
        if (titleEl) titleEl.textContent = LOGOUT_FAILED_TITLE;
        if (bodyEl) bodyEl.textContent = LOGOUT_FAILED_MESSAGE;
        function close() {
          dialog.close();
          dialog.remove();
        }
        dialog.querySelectorAll('[data-ticket-logout-close]').forEach(function (el) { el.addEventListener('click', close); });
        dialog.querySelector('.ticket-redeem__modal-backdrop')?.addEventListener('click', close);
        dialog.addEventListener('click', function (e) { if (e.target === dialog) close(); });
        document.body.appendChild(dialog);
        dialog.showModal();
      }
  
      function showModalMessage(message, isError) {
        if (!modalResponse || !modalResponseText) return;
        modalResponseText.textContent = message;
        modalResponse.classList.remove('hidden', 'ticket-redeem__response--error', 'ticket-redeem__response--success');
        modalResponse.classList.add(isError ? 'ticket-redeem__response--error' : 'ticket-redeem__response--success');
      }
  
      function hideModalMessage() {
        if (modalResponse) modalResponse.classList.add('hidden');
      }
  
      function setLoading(loading) {
        if (submitBtn && submitText && submitLoading) {
          submitBtn.disabled = loading;
          submitText.classList.toggle('hidden', loading);
          submitLoading.classList.toggle('hidden', !loading);
        }
      }
  
      function renderUI() {
        const token = getStored();
        function nonEmptyUrl(u) {
          return (u && typeof u === 'string' && u.trim() !== '') ? u : null;
        }
        const data = token ? decodeTokenPayload(token) : null;
        if (data && !isPayloadExpired(data)) {
          if (stateInput) stateInput.hidden = true;
          if (stateLoggedIn) stateLoggedIn.hidden = false;
          if (lockedImageWrap) lockedImageWrap.hidden = true;
          const ticketType = (data.ticketType != null && data.ticketType !== '') ? (data.ticketType).toString().toLowerCase() : ((data.ticket_type != null && data.ticket_type !== '') ? (data.ticket_type).toString().toLowerCase() : '');
          const typeUrl = ticketType ? (imageByType[ticketType] || null) : null;
          const apiUrl = nonEmptyUrl(data.ticketTypeImage) || nonEmptyUrl(data.ticket_type_image) || nonEmptyUrl(data.image_url);
          const imgUrl = nonEmptyUrl(typeUrl) || apiUrl;
          if (imgUrl && ticketTypeImage && ticketTypeImageWrap) {
            ticketTypeImage.src = imgUrl;
            ticketTypeImage.alt = ticketType ? (ticketType.charAt(0).toUpperCase() + ticketType.slice(1)) : 'Ticket';
            ticketTypeImageWrap.hidden = false;
          } else if (ticketTypeImageWrap) {
            ticketTypeImageWrap.hidden = true;
          }
        } else {
          if (data && isPayloadExpired(data)) {
            clearStored();
          }
          if (stateInput) stateInput.hidden = false;
          if (stateLoggedIn) stateLoggedIn.hidden = true;
          if (ticketTypeImageWrap) ticketTypeImageWrap.hidden = true;
          const lockedUrl = nonEmptyUrl(defaultImageUrl);
          if (lockedUrl && lockedImage && lockedImageWrap) {
            lockedImage.src = lockedUrl;
            lockedImage.alt = 'Locked ticket';
            lockedImageWrap.hidden = false;
          } else if (lockedImageWrap) {
            lockedImageWrap.hidden = true;
          }
        }
      }
  
      const customerLoggedIn = wrapper.getAttribute('data-customer-logged-in') === 'true';
      const customerEmail = wrapper.getAttribute('data-customer-email') || '';

      function openLoginModal() {
        if (loginModal) loginModal.showModal();
      }

      function closeLoginModal() {
        if (loginModal) loginModal.close();
      }

      function openModal() {
        if (!customerLoggedIn) {
          openLoginModal();
          return;
        }
        if (!modal) return;
        hideModalMessage();
        if (modalInput) {
          modalInput.value = '';
          modalInput.focus();
        }
        modal.showModal();
      }
  
      function closeModal() {
        if (modal) modal.close();
      }
  
      window.addEventListener('ticketRedeemDataChange', renderUI);
      openModalBtn?.addEventListener('click', openModal);
      logoutBtn?.addEventListener('click', async function () {
        const token = getTokenFromStored();
        if (token) {
          try {
            const response = await fetch('/apps/redeem/logout', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest',
                Accept: 'application/json'
              },
              body: JSON.stringify({ token: token })
            });
            const data = await response.json().catch(function () { return {}; });
            if (typeof window.handleRedeemApiResponse === 'function' && window.handleRedeemApiResponse(response, data)) {
              if (response && response.status === 401) return;
            }
            if (data.success !== true) {
              showLogoutFailedModal();
            }
            const prizeReason = data.success === true ? PRIZE_REMOVED_TICKET_LOGOUT : '';
            if (typeof window.removePrizeItemsFromCart === 'function') {
              await window.removePrizeItemsFromCart(prizeReason);
            }
            if (typeof window.removeTicketPrizeDiscountsFromCart === 'function') {
              await window.removeTicketPrizeDiscountsFromCart();
            }
          } catch (_) {}
        }
        clearStored();
        renderUI();
      });
      modalCloseBtns.forEach(function (el) {
        el.addEventListener('click', closeModal);
      });
      modal?.addEventListener('click', function (e) {
        if (e.target === modal) closeModal();
      });
      wrapper.querySelector('[data-ticket-modal] .ticket-redeem__modal-backdrop')?.addEventListener('click', closeModal);

      loginModalCloseBtns.forEach(function (el) {
        el.addEventListener('click', closeLoginModal);
      });
      loginModal?.addEventListener('click', function (e) {
        if (e.target === loginModal) closeLoginModal();
      });
      wrapper.querySelector('[data-ticket-login-modal] .ticket-redeem__modal-backdrop')?.addEventListener('click', closeLoginModal);
  
      modalForm?.addEventListener('submit', async function (e) {
        e.preventDefault();
        if (!modalInput?.value?.trim()) return;
  
        const code = modalInput.value.trim();
        setLoading(true);
        hideModalMessage();
  
        try {
          const body = new FormData();
          body.append('code', code);
          body.append('form_type', 'ticket_redeem');
          if (customerEmail) body.append('email', customerEmail);
  
          const response = await fetch('/apps/redeem', {
            method: 'POST',
            body: body,
            headers: {
              'X-Requested-With': 'XMLHttpRequest',
              Accept: 'application/json'
            }
          });
  
          const contentType = response.headers.get('Content-Type') || '';
          let message = '';
          let isError = !response.ok;
          let data = null;
  
          if (contentType.includes('application/json')) {
            data = await response.json().catch(function () { return {}; });
            message = data.message ?? data.error ?? data.text ?? (isError ? '{{ "sections.ticket_redeem.error_default" | t }}' : '');
            if (data.success === true) isError = false;
            if (data.success === false || data.error) isError = true;
          } else {
            const text = await response.text();
            message = text || (response.ok ? '{{ "sections.ticket_redeem.success_default" | t }}' : '{{ "sections.ticket_redeem.error_default" | t }}');
          }
  
          if (!message) {
            message = response.ok ? '{{ "sections.ticket_redeem.success_default" | t }}' : '{{ "sections.ticket_redeem.error_default" | t }}';
          }
  
          if (typeof window.handleRedeemApiResponse === 'function' && window.handleRedeemApiResponse(response, data || {})) {
            if (response && response.status === 401) {
              showModalMessage(message || 'Your token is invalid or expired.', true);
            } else {
              showModalMessage(message, false);
              if (response.ok && data && typeof data.token === 'string' && data.token.trim()) {
                syncGoldenRedeemCodeStorage(code, data.token.trim());
              }
              closeModal();
              renderUI();
            }
          } else {
            showModalMessage(message, isError);
            if (!isError && response.ok && data && typeof data === 'object' && typeof data.token === 'string' && data.token.trim()) {
              if (typeof window.applyRedeemTokenAndSync === 'function') {
                window.applyRedeemTokenAndSync(data.token);
              } else {
                setStored(data.token);
                if (typeof window.refreshPrizeProductState === 'function') window.refreshPrizeProductState();
              }
              syncGoldenRedeemCodeStorage(code, data.token.trim());
              closeModal();
              renderUI();
            }
          }
        } catch (_) {
          showModalMessage('{{ "sections.ticket_redeem.error_network" | t }}', true);
        } finally {
          setLoading(false);
        }
      });
  
      renderUI();
    })();
  </script>
  
  {% stylesheet %}
    .ticket-redeem {
      width: 100%;
    }

    .ticket-redeem__inner {
      max-width: var(--page-width, 1200px);
      margin-inline: auto;
      padding-inline: var(--padding-page);
      display: flex;
      flex-direction: column;
      align-items: var(--ticket-align-items-desktop, flex-start);
      text-align: var(--ticket-align-desktop, left);
    }

    .ticket-redeem__heading {
      margin-bottom: var(--gap-md);
      width: 100%;
    }

    .ticket-redeem__form-wrapper {
      display: flex;
      flex-direction: column;
      gap: var(--gap-md);
      max-width: 28rem;
      width: 100%;
      align-items: var(--ticket-align-items-desktop, flex-start);
    }

    @media screen and (max-width: 749px) {
      .ticket-redeem__inner {
        align-items: var(--ticket-align-items-mobile, flex-start);
        text-align: var(--ticket-align-mobile, left);
      }
      .ticket-redeem__form-wrapper {
        align-items: var(--ticket-align-items-mobile, flex-start);
      }
    }
  
    .ticket-redeem__state[hidden] {
      display: none !important;
    }
  
    .ticket-redeem__ticket-display {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: var(--gap-md);
    }
  
    .ticket-redeem__ticket-content {
      display: inline-flex;
      align-items: center;
      gap: var(--gap-sm);
    }
  
    .ticket-redeem__ticket-image-wrap {
      display: inline-block;
    }
  
    .ticket-redeem__ticket-image {
      display: block;
      width: 200px;
      height: auto;
      object-fit: cover;
      border-radius: var(--style-border-radius-inputs);
    }
  
    .ticket-redeem__input,
    .ticket-redeem__modal-input {
      width: 100%;
      min-width: 0;
      padding: var(--padding-lg) var(--padding-xl);
      border-radius: var(--style-border-radius-inputs);
      border: var(--style-border-width-inputs) solid var(--color-input-border);
      background-color: var(--color-input-background);
      color: var(--color-input-text);
      -webkit-font-smoothing: antialiased;
    }
  
    .ticket-redeem__submit {
      flex-shrink: 0;
    }
  
    .ticket-redeem__response,
    .ticket-redeem__modal-response {
      padding: var(--padding-md) var(--padding-lg);
      border-radius: var(--style-border-radius-inputs);
      border: var(--style-border-width-inputs) solid;
      margin-top: 20px;
    }
  
    .ticket-redeem__response--success,
    .ticket-redeem__modal-response.ticket-redeem__response--success {
      border-color: var(--color-success-border, green);
      background: var(--color-success-background, rgba(0, 128, 0, 0.08));
      color: var(--color-success-text, #0a5c0a);
    }
  
    .ticket-redeem__response--error,
    .ticket-redeem__modal-response.ticket-redeem__response--error {
      border-color: var(--color-error-border, #c00);
      background: var(--color-error-background, rgba(204, 0, 0, 0.08));
      color: var(--color-error-text, #c00);
    }
  
    .ticket-redeem__response-text {
      margin: 0;
    }
  
    .ticket-redeem .hidden {
      display: none !important;
    }
  
    /* Modal */
    .ticket-redeem__modal {
      position: fixed;
      inset: 0;
      width: 100%;
      height: 100%;
      border: none;
      padding: 0;
      background: transparent;
    }
  
    .ticket-redeem__modal::backdrop {
      background: rgba(0, 0, 0, 0.5);
    }
  
    .ticket-redeem__modal-backdrop {
      position: absolute;
      inset: 0;
    }
  
    .ticket-redeem__modal-content {
      position: absolute;
      left: 50%;
      top: 50%;
      transform: translate(-50%, -50%);
      width: 90%;
      max-width: 24rem;
      padding: 0;
      background: var(--color-background);
      color: var(--color-foreground);
      border-radius: var(--style-border-radius-inputs);
      border: var(--basic-color) solid 2px;
      box-shadow: 0 -3px 19px -5px rgb(254 201 9), 0 3px 14px -5px rgb(254 201 9);
      overflow: hidden;
    }

    .ticket-redeem__modal-header {
      border-radius: calc(var(--style-border-radius-inputs) - 2px) calc(var(--style-border-radius-inputs) - 2px) 0 0;
    }
  
    .ticket-redeem__modal-title {
      margin: 0 0 var(--gap-md);
      font-size: 1.125rem;
      text-transform: uppercase;
    }

    .ticket-redeem__login-message {
      margin: 0 0 var(--gap-md);
      color: var(--color-foreground);
      text-transform: uppercase;
    }
  
    .ticket-redeem__modal-form {
      display: flex;
      flex-direction: column;
      gap: var(--gap-md);
    }
  
    .ticket-redeem__modal-actions {
      display: flex;
      flex-wrap: wrap;
      gap: var(--gap-sm);
      justify-content: flex-end;
    }

    .ticket-redeem__trigger { 
      text-transform: uppercase;
    }

    .ticket-redeem__modal-content * {
      text-transform: uppercase;
    }

  {% endstylesheet %}
  
